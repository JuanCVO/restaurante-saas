# =========================
# MONOREPO GENERAL
# =========================
# Entornos / secretos (ajusta si tienes .env.example que sí deba leer)
.env
.env.*
*.env.*
*.local
*.secret
*.secrets
*.credentials
secrets/
config/**/secrets.*
config/**/credentials.*

# Claves y certificados
*.pem
*.key
*.crt
*.pfx
*.p12
*.keystore
*.jks
*.gpg
*.asc

# Directorios de herramientas/cloud
.ssh/
.aws/
.gcloud/
.azure/
.kube/
.docker/

# Lockfiles grandes
package-lock.json
yarn.lock
pnpm-lock.yaml
bun.lockb

# Configs de IDE / sistema
.DS_Store
Thumbs.db
.idea/
.vscode/
*.iml
*.swp
*.swo
*.suo

# Logs y temporales
*.log
logs/
log/
*.tmp
*.temp
*.pid
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Backups de editores
*~
*.bak
*.orig
*.rej

# =========================
# BACKEND
# =========================
backend/node_modules/
backend/dist/
backend/generated/
backend/.cache/
backend/coverage/
backend/.nyc_output/

# Si generas clientes a partir de OpenAPI/Prisma/etc.
backend/**/__generated__/
backend/**/generated/
backend/**/*.generated.*
backend/**/*.gen.*

# Bases de datos o dumps grandes (si los hubiera)
backend/**/*.sqlite
backend/**/*.sqlite3
backend/**/*.db
backend/**/*.sql
backend/**/*.dump

# =========================
# FRONTEND
# =========================
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/.turbo/
frontend/.cache/
frontend/coverage/
frontend/.nyc_output/

# Assets estáticos pesados (imágenes, etc.)
frontend/public/
frontend/static/
frontend/assets/
frontend/media/
frontend/images/

# Storybook / docs generadas (si las usas)
frontend/storybook-static/
frontend/.storybook-out/
frontend/.storybook-cache/
frontend/docs-build/
frontend/.docz/

# =========================
# TESTS / REPORTES (ambos)
# =========================
**/__snapshots__/
**/*.snap
**/jest-report/
**/jest-results/
**/cypress/videos/
**/cypress/screenshots/
**/playwright-report/
**/test-output/
**/reports/